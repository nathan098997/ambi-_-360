# Configuração para Apache (.htaccess)\n# Descomente se estiver usando Apache\n\n# <IfModule mod_headers.c>\n#     Header always set X-Content-Type-Options nosniff\n#     Header always set X-Frame-Options SAMEORIGIN\n#     Header always set X-XSS-Protection \"1; mode=block\"\n# </IfModule>\n\n# <IfModule mod_expires.c>\n#     ExpiresActive on\n#     ExpiresByType text/css \"access plus 1 day\"\n#     ExpiresByType application/javascript \"access plus 1 day\"\n#     ExpiresByType image/svg+xml \"access plus 1 week\"\n# </IfModule>\n\n# Configuração para Nginx\n# Adicione no seu nginx.conf:\n\n# location ~* \\.(css|js|svg|png|jpg|jpeg)$ {\n#     expires 1d;\n#     add_header Cache-Control \"public, immutable\";\n# }\n\n# location / {\n#     try_files $uri $uri/ /index.html;\n# }\n\n# Para desenvolvimento local, não é necessário configurar nada\n# O servidor Express já está configurado corretamente