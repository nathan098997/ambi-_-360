# =============================================
# AMBI360 - Configurações de Ambiente
# =============================================

# Configurações da Aplicação
APP_PORT=3005
APP_ENV=development
APP_SECRET_KEY=TROQUE_POR_UMA_CHAVE_ALEATORIA_LONGA

# Configurações de Segurança
# ADMIN_PASSWORD deve ser definida aqui — nunca commite este arquivo
ADMIN_PASSWORD=TROQUE_POR_SUA_SENHA
JWT_SECRET=TROQUE_POR_UM_JWT_SECRET_LONGO_E_ALEATORIO
SESSION_SECRET=TROQUE_POR_UM_SESSION_SECRET_LONGO_E_ALEATORIO
BCRYPT_ROUNDS=12

# Configurações de Upload
MAX_FILE_SIZE=50MB
UPLOAD_PATH=./uploads
ALLOWED_EXTENSIONS=jpg,jpeg,png,gif,svg

# Debug e Logs
DEBUG_MODE=false
LOG_LEVEL=info

# Banco de Dados (Opcional - DESABILITADO)
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=
# DB_PASSWORD=
# DB_NAME=ambi360_db